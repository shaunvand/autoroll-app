{
  "expo": {
    "name": "Autoroll",
    "slug": "autoroll",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "autoroll",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "online.autoroll.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FF5A5F"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "autoroll.online", "pathPrefix": "/app" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoroll uses photos you select to enhance and post them to Instagram."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF5A5F"
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "apiBase": "https://api.autoroll.online",
      "metaAppId": "1491705065689201",
      "fbOauthRedirect": "https://autoroll.online/app/fb-callback"
    }
  }
}
